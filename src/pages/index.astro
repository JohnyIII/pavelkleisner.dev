---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import CtaBand from "@/components/CtaBand.astro";
---

<Layout title="Pavel Kleisner - Senior Backend & Integration Engineer">

    <PageIntro
        eyebrow="Senior Backend & Integration Engineer"
        title="Pavel Kleisner"
        lead="Backend, integration and release work for systems where production mistakes are expensive."
        body="I mainly work with Kotlin, Java, Spring and PostgreSQL. In recent years my focus has been TSM/CETIN production flow: B2B behavior, data compatibility, incident analysis, new version rollout and the places where business rules meet runtime reality."
    >
        <p>
            I am not a “full-stack generalist for everything”. I am a backend-heavy
            programmer who can still read the frontend, database and operational logs
            when the real cause is spread across the system.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
            <a href="/projects" class="btn-primary">View experience</a>
            <a href="/contact" class="btn-secondary">Contact</a>
        </div>
    </PageIntro>

    <section class="mb-24">
        <div class="fact-strip">
            <div>
                <div class="fact-value">9+</div>
                <div class="fact-label">years in software</div>
            </div>
            <div>
                <div class="fact-value">5700+</div>
                <div class="fact-label">tracked work commits</div>
            </div>
            <div>
                <div class="fact-value">TSM</div>
                <div class="fact-label">2.2 / 2.4 production rollouts</div>
            </div>
            <div>
                <div class="fact-value">Prague</div>
                <div class="fact-label">Czech Republic</div>
            </div>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Where I fit best"
            body="The value is usually not another abstraction layer. It is a change that survives real data, integrations, support and the next release."
        />
        <ul class="note-list">
            <li><strong>Integrations</strong><span>B2B APIs, process flows, message behavior, retries, logs and failure modes that only become visible after deployment.</span></li>
            <li><strong>Releases</strong><span>Rolling new versions into real environments while watching compatibility, old data and operational risk.</span></li>
            <li><strong>Architecture</strong><span>Small safe changes, clearly named rules and service boundaries. No ceremony around patterns.</span></li>
            <li><strong>Debugging</strong><span>Incidents through logs, metrics, databases and domain context. Not random patches around symptoms.</span></li>
        </ul>
    </section>

    <section class="mb-24">
        <SectionIntro title="Core stack" />
        <div class="flex flex-wrap gap-2">
            <span class="pill">Kotlin</span>
            <span class="pill">Java</span>
            <span class="pill">Spring</span>
            <span class="pill">PostgreSQL</span>
            <span class="pill">Kafka</span>
            <span class="pill">Kubernetes</span>
            <span class="pill">Angular</span>
            <span class="pill">Oracle</span>
            <span class="pill">Astro</span>
            <span class="pill">TypeScript</span>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Experience snapshot"
            body="Most of my professional work is internal or client-owned, so I describe responsibility and production context rather than exposing code."
        />
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <InfoCard title="TSM / CETIN" meta="2020 - present" tag="main focus">
                Senior backend and integration work on Kotlin/Java/Spring services, PostgreSQL-backed systems, B2B flows, PEW, NIP, change management and production rollout of new platform versions.
            </InfoCard>
            <InfoCard title="ZIS" meta="2017 - 2018" tag="foundation">
                Enterprise Java and ZK/ZUL work across screens, controllers, services, DAO layers, imports, Excel processing and production bug fixes.
            </InfoCard>
            <InfoCard title="MNCP" meta="2018 - 2021" tag="full-stack">
                Kotlin/Spring, Angular and database work around authentication, measuring batches, archives, exports and operational fixes.
            </InfoCard>
        </div>
    </section>

    <CtaBand
        title="Interested in collaboration?"
        body="If you need a senior engineer for backend systems, integrations, production releases or long-term product development, email is the fastest channel."
        href="/contact"
        label="Get in touch"
    />

</Layout>
