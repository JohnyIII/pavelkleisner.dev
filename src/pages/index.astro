---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import CtaBand from "@/components/CtaBand.astro";
---

<Layout title="Pavel Kleisner - Senior Backend & Integration Engineer">

    <PageIntro
        eyebrow="Senior Backend & Integration Engineer"
        title="Pavel"
        highlight="Kleisner"
        lead="I build and ship production backend systems for telecom and enterprise environments."
        body="My strongest area is the place where domain rules, data, integrations and releases meet. I work mainly with Kotlin, Java, Spring and PostgreSQL, with recent focus on TSM production rollouts, B2B behavior, observability and incident analysis."
    >
        <div class="flex flex-wrap gap-3 mt-8">
            <a href="/projects" class="btn-primary">View experience</a>
            <a href="/contact" class="btn-secondary">Contact</a>
        </div>
    </PageIntro>

    <section class="mb-24">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="info-card">
                <div class="text-2xl font-semibold">9+</div>
                <div class="text-sm text-slate-400 mt-1">Years in software</div>
            </div>
            <div class="info-card">
                <div class="text-2xl font-semibold">5700+</div>
                <div class="text-sm text-slate-400 mt-1">Tracked work commits</div>
            </div>
            <div class="info-card">
                <div class="text-2xl font-semibold">TSM</div>
                <div class="text-sm text-slate-400 mt-1">2.2 / 2.4 production</div>
            </div>
            <div class="info-card">
                <div class="text-2xl font-semibold">Prague</div>
                <div class="text-sm text-slate-400 mt-1">Czech Republic</div>
            </div>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="What I bring"
            body="A backend-first profile with enough full-stack, data and production context to own real system behavior."
        />
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
            <InfoCard title="Production integrations">
                B2B APIs, process flows, message-driven behavior, retries, logs and failure modes that matter after deployment.
            </InfoCard>
            <InfoCard title="Release ownership">
                Rolling new versions into real environments while watching compatibility, data shape and operational risk.
            </InfoCard>
            <InfoCard title="Pragmatic architecture">
                Small safe changes, named business rules, clear service boundaries and code that can survive future requirements.
            </InfoCard>
            <InfoCard title="Full-stack context">
                Backend work with enough frontend and database experience to understand the whole production flow.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Core stack" />
        <div class="flex flex-wrap gap-2">
            <span class="pill">Kotlin</span>
            <span class="pill">Java</span>
            <span class="pill">Spring</span>
            <span class="pill">PostgreSQL</span>
            <span class="pill">Kafka</span>
            <span class="pill">Kubernetes</span>
            <span class="pill">Angular</span>
            <span class="pill">Oracle</span>
            <span class="pill">Astro</span>
            <span class="pill">TypeScript</span>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Experience snapshot"
            body="Most of my professional work is internal or client-owned, so I describe responsibility and production context rather than exposing code."
        />
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <InfoCard title="TSM / CETIN" meta="2020 - present" tag="main focus">
                Senior backend and integration work on Kotlin/Java/Spring services, PostgreSQL-backed systems, B2B flows, PEW, NIP, change management and production rollout of new platform versions.
            </InfoCard>
            <InfoCard title="ZIS" meta="2017 - 2018" tag="foundation">
                Enterprise Java and ZK/ZUL work across screens, controllers, services, DAO layers, imports, Excel processing and production bug fixes.
            </InfoCard>
            <InfoCard title="MNCP" meta="2018 - 2021" tag="full-stack">
                Kotlin/Spring, Angular and database work around authentication, measuring batches, archives, exports and operational fixes.
            </InfoCard>
        </div>
    </section>

    <CtaBand
        title="Interested in collaboration?"
        body="If you need a senior engineer for backend systems, integrations, production releases or long-term product development, email is the fastest channel."
        href="/contact"
        label="Get in touch"
    />

</Layout>
