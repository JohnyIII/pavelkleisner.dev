---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import TimelineItem from "@/components/TimelineItem.astro";
---

<Layout title="Projekty a zkušenosti - Pavel Kleisner">

    <PageIntro
        title="Postavené pro"
        highlight="reálný svět"
        lead="Dlouhověké platformy, produkční integrace a pár vlastních nápadů."
        body="Většina klientských systémů je neveřejná, proto ukazuju to podstatné: co jsem měl na starosti, na jakých omezeních záleželo a co mě práce naučila. Společná linka je jednoduchá — pochopit doménu, udělat nejmenší bezpečnou změnu a zůstat i u toho, co přijde po nasazení."
    />

    <section class="mb-24">
        <SectionIntro title="Přehled projektů" />
        <div class="project-grid">
            <InfoCard title="TSM platforma" tag="Produkce" variant="accent">
                Seniorní backend a integrační práce na moderní service management platformě:
                Kotlin/Java/Spring služby, PostgreSQL, B2B komunikace, procesní toky,
                analýza incidentů a produkční rollouty verzí 2.2 a 2.4.
                <p class="mt-4 text-sm card-meta">Stack: Kotlin, Java, Spring, PostgreSQL, Kafka, Kubernetes</p>
            </InfoCard>

            <InfoCard title="ZIS" tag="Enterprise">
                Enterprise Java aplikace se ZK/ZUL UI, controllery,
                službami, DAO vrstvou, importy, Excelem a produkčními opravami.
                Fáze, kde jsem se naučil dodávat kompletní business funkcionalitu.
                <p class="mt-4 text-sm card-meta">Stack: Java, ZK, ZUL, Maven, SQL</p>
            </InfoCard>

            <InfoCard title="MNCP" tag="Full-stack">
                Full-stack práce napříč backendem, frontendem a databázovými skripty:
                autentizace, exporty, archivy, měřící dávky, provozní opravy
                a chování celého flow od UI po persistenci.
                <p class="mt-4 text-sm card-meta">Stack: Kotlin, Spring, Angular, Oracle/PostgreSQL</p>
            </InfoCard>

            <InfoCard title="Nordic a vlastní věci" tag="Průběžně · nárazově">
                Nárazová spolupráce v Django web stacku a vlastní experimenty.
                Objemově toho dnes není moc, ale spolupráce trvá. Dobrá připomínka,
                že inženýrské návyky mají být přenositelné napříč technologiemi
                a ne závislé na jednom ekosystému.
                <p class="mt-4 text-sm card-meta">Stack: Python, Django, templates, Astro, TypeScript</p>
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Časová osa projektů"
            body="Timeline ukazuje posun od dodávání kompletních funkcí přes full-stack ownership až k produkčním integracím a release ownershipu."
        />

        <div class="timeline space-y-4">
            <TimelineItem title="ZIS" period="2017 - 2018">
                <p class="mb-4">
                    Enterprise aplikace pro CETIN provoz. Pracoval jsem na Java/ZK obrazovkách,
                    controller-service-DAO flow, importech, Excel zpracování a produkčních defektech.
                </p>
                <ul class="space-y-2">
                    <li>Dodával jsem kompletní business obrazovky od UI po persistenci.</li>
                    <li>Práce v klasickém enterprise Java stacku se silnými procesními a datovými omezeními.</li>
                    <li>Základ pro pozdější backendový a integrační ownership.</li>
                </ul>
            </TimelineItem>

            <TimelineItem title="MNCP" period="2018 - 2021">
                <p class="mb-4">
                    Full-stack projekt kolem měření, archivů, exportů a provozních workflow.
                    Tahle fáze mě posunula od dodávání funkcí k ownershipu chování napříč
                    backendem, frontendem a databází.
                </p>
                <ul class="space-y-2">
                    <li>Kotlin/Spring, Angular, databázové skripty a provozní věci kolem nasazení.</li>
                    <li>Autentizace, exporty, archivní filtry a chování měřících dávek.</li>
                    <li>Ladění problémů přes celý request a datový tok, ne jen v jedné vrstvě.</li>
                </ul>
            </TimelineItem>

            <TimelineItem title="TSM / CETIN" period="2020 - současnost">
                <p class="mb-4">
                    Moje hlavní dlouhodobé zaměření: backendová a integrační práce na moderní TSM platformě.
                    Jsem blízko produkčnímu chování, releasům, B2B komunikaci, procesním pravidlům
                    a datové kompatibilitě.
                </p>
                <ul class="space-y-2">
                    <li>Produkční rollout zkušenost s verzemi TSM 2.2 a 2.4.</li>
                    <li>Integrace kolem NIP, ticketingu, change managementu, B2B, PEW a souvisejících flow.</li>
                    <li>Analýza incidentů přes logy, metriky a doménovou znalost místo slepého patchování.</li>
                    <li>Moderní stack: Kotlin, Java, Spring, PostgreSQL, Kafka-style messaging a Kubernetes prostředí.</li>
                </ul>
            </TimelineItem>

            <TimelineItem title="Nordic Web" period="2024 - současnost · nárazově">
                <p class="mb-4">
                    Pokračující nárazová spolupráce na Django web systému. Objemově toho dnes není moc,
                    ale spolupráce trvá — naskakuju, když je potřeba udělat cílenou změnu. Hodnota
                    je ve schopnosti vstoupit do jiného stacku a udělat přesnou změnu bez násilného
                    přenášení známých patternů.
                </p>
                <ul class="space-y-2">
                    <li>Self-service a webové chování v Python/Django/templates stacku.</li>
                    <li>Cílené produkčně orientované změny v existujícím codebase.</li>
                </ul>
            </TimelineItem>

            <TimelineItem title="Osobní web a experimenty" period="průběžně">
                <p class="mb-4">
                    Menší vlastní projekty mi drží viditelný celý životní cyklus produktu:
                    nápad, implementaci, nasazení, údržbu a zpětnou vazbu. Tenhle web je jeden z nich.
                </p>
                <ul class="space-y-2">
                    <li>Astro, TypeScript, Tailwind CSS a Cloudflare Pages.</li>
                    <li>Jednoduchá statická architektura, dvojjazyčný obsah a nízkoúdržbové nasazení.</li>
                </ul>
            </TimelineItem>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Vlastní projekty"
            body="Menší produkty mě drží u celého cyklu: nápadu, použitelného rozhraní, nasazení, dat i nepříjemných otázek, které izolovaný ticket nikdy nepoloží."
        />
        <div class="project-grid">
            <InfoCard title="Incremental webová hra" tag="Ve vývoji" variant="personal">
                TypeScript a Svelte 5 hra postavená kolem celého loopu: progrese, stav,
                balanc, zpětná vazba a tempo dlouhých herních sezení. Zároveň praktická
                laboratoř pro práci s AI bez odevzdání inženýrského úsudku.
                <p class="mt-4 text-sm card-meta">Svelte 5 · TypeScript · herní systémy</p>
            </InfoCard>
            <InfoCard title="Plánovač rekonstrukce" tag="Self-hosted">
                Účelová aplikace pro porovnávání nabídek, dokumenty a skici na jednom místě
                a přehlednější rozhodování v jinak dost chaotickém reálném procesu.
                <p class="mt-4 text-sm card-meta">Next.js · Drizzle ORM · PostgreSQL</p>
            </InfoCard>
            <InfoCard title="Experimenty s trading botem" tag="Výzkum">
                Python/Freqtrade hřiště pro trend-following, EMA crossover a řízení rizika
                přes ATR. Vzniklo pro ověřování předpokladů na datech, ne pro prodávání jistoty.
                <p class="mt-4 text-sm card-meta">Python · Freqtrade · časové řady</p>
            </InfoCard>
        </div>
    </section>

    <section class="mb-8">
        <SectionIntro title="Přístup k projektům" />
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <InfoCard title="Konkrétní ownership">
                Dobrý projekt je ten, kde se společně chápe runtime chování,
                datový model, release cesta i support po nasazení.
            </InfoCard>
            <InfoCard title="Doména před frameworkem">
                Stacky se mění, doméně je to jedno. Opravy, na které jsem nejvíc
                hrdý, vznikly z pochopení, proč se systém chová tak, jak se chová —
                ne ze znalosti nejnovějšího API.
            </InfoCard>
        </div>
    </section>

</Layout>
