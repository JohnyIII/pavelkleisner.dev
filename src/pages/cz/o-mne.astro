---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import TimelineItem from "@/components/TimelineItem.astro";
import CtaBand from "@/components/CtaBand.astro";
---

<Layout title="O mně - Pavel Kleisner">

    <PageIntro
        title="O"
        highlight="mně"
        lead="Jsem senior backend a integrační vývojář zaměřený na Kotlin, Javu, Spring, PostgreSQL a produkční systémy."
        body="Nejlépe funguju tam, kde záleží na korektnosti, kompatibilitě, observabilitě a bezpečném releasu. Můj současný profil není jen psaní backendového kódu. Je to ownership místa, kde se potkává implementace, doménové chování, integrační kontrakty a produkční releasy."
    />

    <section class="mb-24">
        <SectionIntro title="Jak přemýšlím o softwaru" />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <InfoCard title="Malé explicitní změny">
                V produkčních systémech je často bezpečnější dobře pojmenované
                business pravidlo, izolované mapování, lepší fallback nebo cílený test
                než velký přepis.
            </InfoCard>
            <InfoCard title="Moderní s důvodem">
                Nové verze, frameworky a infrastruktura dávají smysl, když systém
                dělají spolehlivější, lépe pozorovatelný nebo snazší na změnu.
            </InfoCard>
            <InfoCard title="Runtime ownership">
                Skutečný systém začíná po nasazení: stará data, retry,
                externí kontrakty, logy, metriky a supportovatelnost.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Profesní cesta"
            body="Zkrácená timeline toho, jak se moje odpovědnost vyvíjela napříč projekty a stacky."
        />
        <div class="timeline space-y-4">
            <TimelineItem title="2017-2018: ZIS">
                Enterprise Java, ZK/ZUL obrazovky, controllery, služby,
                DAO vrstvy, importy a produkční opravy. Fáze, kde jsem se naučil
                dodávat kompletní aplikační funkcionalitu.
            </TimelineItem>
            <TimelineItem title="2019-2020: MNCP">
                Full-stack práce přes Kotlin/Spring, Angular a databázové skripty.
                Security, exporty, archivy, měřící dávky a provozní opravy
                napříč celým flow.
            </TimelineItem>
            <TimelineItem title="2020-současnost: TSM">
                Seniorní backend a integrační práce na Kotlin/Java/Spring službách,
                PostgreSQL, integračních tocích, B2B komunikaci, analýze incidentů
                a produkčních rolloutech nových verzí.
            </TimelineItem>
            <TimelineItem title="2024-současnost: Nordic / Django (nárazově)">
                Pokračující nárazová spolupráce v Django stacku a vlastní experimenty.
                Objem teď není velký, ale spolupráce trvá. Připomínka, že dobré inženýrské
                návyky mají být přenositelné napříč stacky, ne závislé na jednom frameworku.
            </TimelineItem>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Pracovní styl" />
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <InfoCard title="Architektura a odpovědnost">
                Dobrá architektura není o složitosti nebo diagramech.
                Je o odpovědnosti, ownershipu a pochopení míst, kde změna patří
                a kde už škodí.
            </InfoCard>
            <InfoCard title="Spolupráce">
                Nejlepší řešení vznikají spoluprací vývojářů, analytiků,
                product ownerů a provozu. Technická rozhodnutí mají sloužit
                produktu a lidem, kteří ho drží v chodu.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Čemu se záměrně vyhýbám" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <InfoCard title="Over-engineering">
                Nepřidávám architekturu, která nesnižuje reálnou složitost,
                riziko nebo náklady na údržbu.
            </InfoCard>
            <InfoCard title="Rozhodnutí podle trendů">
                Moderní nástroje mám rád, ale jen když zlepšují dodávku,
                spolehlivost nebo pochopení systému.
            </InfoCard>
            <InfoCard title="Architektura pro jednoho člověka">
                Systém není dobře navržený, pokud ho bezpečně umí měnit jen jeden člověk.
            </InfoCard>
            <InfoCard title="Ego v technických rozhodnutích">
                Technická rozhodnutí mají sloužit produktu a runtime chování,
                ne osobnímu vkusu.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Mimo kód" />
        <p class="max-w-4xl card-body leading-relaxed">
            Ve volném čase mám rád hudbu, sci-fi, fantasy a anime.
            Vlastní projekty mi umožňují zkoušet nové nápady bez tlaku produkčních deadline.
            Rád stavím věci od začátku do konce, protože to udržuje viditelný celý
            životní cyklus produktu: nápad, implementaci, nasazení, údržbu a zpětnou vazbu.
        </p>
    </section>

    <CtaBand
        title="Pojďme spolupracovat"
        body="Pokud tenhle přístup odpovídá tomu, co potřebuješ, ozvi se."
        href="/cz/kontakt"
        label="Kontakt"
    />

</Layout>
