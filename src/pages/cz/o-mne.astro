---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import TimelineItem from "@/components/TimelineItem.astro";
import CtaBand from "@/components/CtaBand.astro";
import StatusReadout from "@/components/StatusReadout.astro";
---

<Layout title="O mně - Pavel Kleisner">

    <PageIntro
        title="Člověk"
        highlight="za kódem"
        lead="Klidný pragmatik, kterého pořád upřímně baví věci tvořit, opravovat a dotahovat."
        body="V DataLite jsem od roku 2017 a vyrostl jsem tu od juniora přes seniorního vývojáře až k team leadovi. Nejlíp mi je tam, kde záleží na správnosti, kompatibilitě a bezpečnosti releasů — kde se implementace potká s doménou, integračními kontrakty a produkcí. Rád pomáhám, pořád se učím a nehraju si na víc, než jsem."
        photo="/pavel.jpg"
        photoAlt="Pavel Kleisner"
        photoLabel="Nejdřív člověk · potom vývojář"
    />

    <section class="mb-24">
        <SectionIntro title="Jak přemýšlím o softwaru" />
        <div class="cards-editorial">
            <InfoCard title="Malé, jasné změny">
                V živém systému většinou přesně pojmenované pravidlo, izolovaný mapping nebo
                jeden cílený test porazí velký rewrite. Míň věcí, co se ve dvě ráno rozbije.
            </InfoCard>
            <InfoCard title="Moderní, když se to vyplatí">
                Mám rád nové verze a nástroje — ale jen když dělají systém spolehlivější,
                přehlednější nebo snazší na změnu. Ne kvůli životopisu.
            </InfoCard>
            <InfoCard title="Nasazením to nekončí">
                Skutečný systém začíná po nasazení: stará data, retry, externí kontrakty,
                logy, metriky a ten, kdo to bude supportovat.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Profesní cesta"
            body="Zkrácená timeline toho, jak se moje odpovědnost vyvíjela napříč projekty a stacky."
        />
        <div class="timeline space-y-4">
            <TimelineItem title="2017-2018: ZIS">
                Enterprise Java, ZK/ZUL obrazovky, controllery, služby,
                DAO vrstvy, importy a produkční opravy. Fáze, kde jsem se naučil
                dodávat kompletní aplikační funkcionalitu.
            </TimelineItem>
            <TimelineItem title="2018-2021: MNCP">
                Full-stack práce přes Kotlin/Spring, Angular a databázové skripty.
                Security, exporty, archivy, měřící dávky a provozní opravy
                napříč celým flow.
            </TimelineItem>
            <TimelineItem title="2020-současnost: TSM">
                Seniorní backend a integrační práce na Kotlin/Java/Spring službách,
                PostgreSQL, integračních tocích, B2B komunikaci, analýze incidentů
                a produkčních rolloutech nových verzí.
            </TimelineItem>
            <TimelineItem title="2024-současnost: Nordic / Django (nárazově)">
                Pokračující nárazová spolupráce v Django stacku a vlastní experimenty.
                Objem teď není velký, ale spolupráce trvá. Připomínka, že dobré inženýrské
                návyky mají být přenositelné napříč stacky, ne závislé na jednom frameworku.
            </TimelineItem>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Pracovní styl" />
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <InfoCard title="Architektura a odpovědnost">
                Dobrá architektura není o složitosti nebo diagramech.
                Je o odpovědnosti, ownershipu a pochopení míst, kde změna patří
                a kde už škodí.
            </InfoCard>
            <InfoCard title="Spolupráce">
                Nejlepší řešení vznikají spoluprací vývojářů, analytiků,
                product ownerů a provozu. Technická rozhodnutí mají sloužit
                produktu a lidem, kteří ho drží v chodu.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Čemu se záměrně vyhýbám" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <InfoCard title="Over-engineering">
                Architektura, která neubírá reálnou složitost, riziko ani náklady
                na údržbu. Z "flexibilní" abstrakce je za dva roky většinou kód,
                na který se všichni bojí sáhnout.
            </InfoCard>
            <InfoCard title="Big-bang releasy">
                Nasadit všechno najednou a doufat. Rollout potřebuje pořadí,
                fallback a možnost zastavit v půlce — jinak je to sázka.
            </InfoCard>
            <InfoCard title="Architektura pro jednoho člověka">
                Systém není dobře navržený, pokud ho bezpečně umí měnit jen jeden
                člověk. Byl jsem ten člověk — neškáluje to a kazí to dovolené.
            </InfoCard>
            <InfoCard title="Ego v technických rozhodnutích">
                Technická rozhodnutí podle vkusu místo podle produktu. Jednou jsem
                radši přizpůsobil naši stranu starému formátu partnera, než abych
                obhajoval technicky správný spec.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Mimo práci"
            body="Stavím věci od začátku do konce i proto, že mě to baví. Tady je člověk za commity."
        />

        <div class="personal-grid mb-6">
            <InfoCard title="Čtení & audioknihy" variant="personal">
                Asi 125 knih a přibývá — LitRPG (Vasily Mahanenko), spousta české sci-fi/fantasy
                (Kotleta, Sněgoňová, Starý, Kadlečková, Stehlíková) a k tomu Andy Weir, Liu Cixin,
                Sapkowski a Pratchett. Většinu poslouchám jako audioknihy.
            </InfoCard>
            <InfoCard title="Anime">
                Vyrostl jsem na shounen Big 3 (Naruto, One Piece, Bleach). One Piece pořád běží —
                a já se pořád dívám.
            </InfoCard>
            <InfoCard title="Hraní">
                Hlavní způsob, jak vypnout. PlayStation 5, teď hraju 007 First Light.
            </InfoCard>
            <InfoCard title="Metal & kafe & kolo">
                Iron Maiden, Arch Enemy, Jinjer, HammerFall a spol. ve sluchátkách. Kafe čerstvě
                namleté v ručním mlýnku a uvařené v moka konvičce. Kolo, co čeká na repas. Kočky
                i psi vítáni.
            </InfoCard>
            <InfoCard title="Pomoc, která je vidět až na místě" variant="personal">
                Dva roky jsem pomáhal s charitativním plesem pro Charitu Červený Kostelec,
                hlavně tam, kde se zrovna hodil další pár rukou. Po odstěhování jsem skončil,
                ale zůstává to pro mě dobrá vzpomínka na praktickou pomoc místní komunitě.
            </InfoCard>
        </div>

        <p class="card-body mb-4">Kořeny mám v Horní Radechové u Náchoda; dnes bydlím kousek od Prahy.</p>
        <StatusReadout />
    </section>

    <CtaBand
        title="Pojďme spolupracovat"
        body="Pokud tenhle přístup odpovídá tomu, co potřebuješ, ozvi se."
        href="/cz/kontakt"
        label="Kontakt"
    />

</Layout>
