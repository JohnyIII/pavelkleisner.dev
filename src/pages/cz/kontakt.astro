---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import CtaBand from "@/components/CtaBand.astro";
---

<Layout title="Kontakt - Pavel Kleisner">

    <PageIntro
        title="Kontakt"
        lead="Pokud hledáš seniorního backend a integračního vývojáře pro produkční systémy, telekomunikační integrace, release ownership nebo dlouhodobý vývoj produktu, ozvi se."
    />

    <section class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-24">
        <InfoCard title="Email">
            <p class="mb-4">Nejrychlejší způsob, jak mě kontaktovat.</p>
            <a href="mailto:contact@pavelkleisner.dev" class="text-teal-400 hover:text-teal-300 font-medium">
                contact@pavelkleisner.dev
            </a>
        </InfoCard>

        <InfoCard title="LinkedIn">
            <p class="mb-4">Profesní profil a zkušenosti.</p>
            <a
                href="https://www.linkedin.com/in/pavel-kleisner-895989129/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-teal-400 hover:text-teal-300 font-medium"
            >
                Zobrazit profil
            </a>
        </InfoCard>

        <InfoCard title="GitHub">
            <p class="mb-4">Kód, experimenty a vlastní projekty.</p>
            <a
                href="https://github.com/JohnyIII"
                target="_blank"
                rel="noopener noreferrer"
                class="text-teal-400 hover:text-teal-300 font-medium"
            >
                github.com/JohnyIII
            </a>
        </InfoCard>
    </section>

    <CtaBand
        title="Otevřený cílené spolupráci"
        body="Největší smysl dávám u systémů, kde záleží na backendovém chování, datech, externích kontraktech a produkčních releasech. Nejlépe funguje jasný scope, reálná odpovědnost a přímá komunikace."
        href="mailto:contact@pavelkleisner.dev"
        label="Napsat email"
    />

</Layout>
