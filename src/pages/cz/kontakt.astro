---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import CtaBand from "@/components/CtaBand.astro";
---

<Layout title="Kontakt - Pavel Kleisner">

    <PageIntro
        title="Pojďme se"
        highlight="domluvit."
        lead="Backend, integrace, vlastnictví releasů nebo produkční problém, který potřebuje rozmotat? Začni krátkým e-mailem — na rovinu řeknu, jestli můžu pomoct."
    />

    <section class="project-grid mb-24">
        <InfoCard title="Email" variant="accent">
            <p class="mb-4">Nejrychlejší cesta. Stačí pár řádků o problému, kontextu a očekávaném rozsahu.</p>
            <a href="mailto:contact@pavelkleisner.dev" class="link-plain">
                contact@pavelkleisner.dev
            </a>
        </InfoCard>

        <InfoCard title="LinkedIn">
            <p class="mb-4">Profesní profil a zkušenosti.</p>
            <a
                href="https://www.linkedin.com/in/pavel-kleisner-895989129/"
                target="_blank"
                rel="noopener noreferrer"
                class="link-plain"
            >
                Zobrazit profil
            </a>
        </InfoCard>

        <InfoCard title="GitHub">
            <p class="mb-4">Kód, experimenty a vlastní projekty.</p>
            <a
                href="https://github.com/JohnyIII"
                target="_blank"
                rel="noopener noreferrer"
                class="link-plain"
            >
                github.com/JohnyIII
            </a>
        </InfoCard>
    </section>

    <CtaBand
        title="Otevřený cílené spolupráci"
        body="Nejvíc sedím tam, kde najednou záleží na backendovém chování, datech, externích kontraktech i produkčních releasech. Jasný scope, reálná odpovědnost a přímá komunikace — tam odvádím nejlepší práci."
        href="mailto:contact@pavelkleisner.dev"
        label="Napiš mi e-mail"
    />

</Layout>
