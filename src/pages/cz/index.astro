---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import CtaBand from "@/components/CtaBand.astro";
---

<Layout title="Pavel Kleisner - Senior Backend & Integration Engineer">

    <PageIntro
        eyebrow="Senior Backend & Integration Engineer"
        title="Pavel Kleisner"
        lead="Backend, integrace a release práce pro systémy, kde chyba po nasazení opravdu něco stojí."
        body="Dělám hlavně Kotlin, Javu, Spring a PostgreSQL. V posledních letech řeším TSM/CETIN produkční flow: B2B chování, datovou kompatibilitu, incidenty, rollout nových verzí a místa, kde se business pravidlo potká s runtime realitou."
    >
        <p>
            Nejsem “full-stack generalista na všechno”. Jsem backendově těžký programátor,
            který umí číst frontend, databázi i provozní logy, když je potřeba najít
            skutečný důvod problému.
        </p>
        <div class="flex flex-wrap gap-3 mt-8">
            <a href="/cz/projekty" class="btn-primary">Zkušenosti</a>
            <a href="/cz/kontakt" class="btn-secondary">Kontakt</a>
        </div>
    </PageIntro>

    <section class="mb-24">
        <div class="fact-strip">
            <div>
                <div class="fact-value">9+</div>
                <div class="fact-label">let ve vývoji</div>
            </div>
            <div>
                <div class="fact-value">5700+</div>
                <div class="fact-label">dohledaných pracovních commitů</div>
            </div>
            <div>
                <div class="fact-value">TSM</div>
                <div class="fact-label">2.2 / 2.4 produkční rollouty</div>
            </div>
            <div>
                <div class="fact-value">Praha</div>
                <div class="fact-label">Česká republika</div>
            </div>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Kde dávám největší smysl"
            body="Největší hodnota není v tom přidat další vrstvu abstrakce. Je v tom udělat změnu, která přežije data, integrace, support a další release."
        />
        <ul class="note-list">
            <li><strong>Integrace</strong><span>B2B API, procesní toky, zprávy, retry chování, logy a chybové stavy, které začnou být důležité až po nasazení.</span></li>
            <li><strong>Releasy</strong><span>Nasazování nových verzí do reálných prostředí se zaměřením na kompatibilitu, stará data a provozní rizika.</span></li>
            <li><strong>Architektura</strong><span>Malé bezpečné změny, jasně pojmenovaná pravidla a hranice služeb. Bez divadla kolem patternů.</span></li>
            <li><strong>Debugging</strong><span>Incidenty přes logy, metriky, databázi a doménový kontext. Ne přes náhodné patchování symptomů.</span></li>
        </ul>
    </section>

    <section class="mb-24">
        <SectionIntro title="Hlavní stack" />
        <div class="flex flex-wrap gap-2">
            <span class="pill">Kotlin</span>
            <span class="pill">Java</span>
            <span class="pill">Spring</span>
            <span class="pill">PostgreSQL</span>
            <span class="pill">Kafka</span>
            <span class="pill">Kubernetes</span>
            <span class="pill">Angular</span>
            <span class="pill">Oracle</span>
            <span class="pill">Astro</span>
            <span class="pill">TypeScript</span>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Zkušenosti v kostce"
            body="Většina mojí práce je interní nebo klientská, takže popisuji hlavně odpovědnost a produkční kontext místo ukazování kódu."
        />
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <InfoCard title="TSM / CETIN" meta="2020 - současnost" tag="hlavní fokus">
                Seniorní backend a integrační práce na Kotlin/Java/Spring službách, PostgreSQL systémech, B2B flow, PEW, NIP, change managementu a produkčních rolloutech nových verzí.
            </InfoCard>
            <InfoCard title="ZIS" meta="2017 - 2018" tag="základ">
                Enterprise Java a ZK/ZUL práce přes obrazovky, controllery, služby, DAO vrstvy, importy, Excel zpracování a produkční opravy.
            </InfoCard>
            <InfoCard title="MNCP" meta="2018 - 2021" tag="full-stack">
                Kotlin/Spring, Angular a databázová práce kolem autentizace, měřících dávek, archivů, exportů a provozních oprav.
            </InfoCard>
        </div>
    </section>

    <CtaBand
        title="Máš zájem o spolupráci?"
        body="Pokud hledáš seniorního vývojáře pro backend, integrace, produkční releasy nebo dlouhodobý vývoj produktu, nejrychlejší je e-mail."
        href="/cz/kontakt"
        label="Napiš mi"
    />

</Layout>
