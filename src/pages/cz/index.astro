---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import CtaBand from "@/components/CtaBand.astro";
---

<Layout title="Pavel Kleisner - Senior Backend & Integration Engineer">

    <PageIntro
        eyebrow="Senior Backend & Integration Engineer"
        title="Pavel"
        highlight="Kleisner"
        lead="Stavím a nasazuji produkční backendové systémy pro telekomunikační a enterprise prostředí."
        body="Nejsilnější jsem tam, kde se potkávají doménová pravidla, data, integrace a releasy. Pracuji hlavně s Kotlinem, Javou, Springem a PostgreSQL, v posledních letech hlavně na TSM produkčních rolloutech, B2B chování, observabilitě a analýze incidentů."
    >
        <div class="flex flex-wrap gap-3 mt-8">
            <a href="/cz/projekty" class="btn-primary">Zkušenosti</a>
            <a href="/cz/kontakt" class="btn-secondary">Kontakt</a>
        </div>
    </PageIntro>

    <section class="mb-24">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <div class="info-card">
                <div class="text-2xl font-semibold">9+</div>
                <div class="text-sm text-slate-400 mt-1">Let ve vývoji</div>
            </div>
            <div class="info-card">
                <div class="text-2xl font-semibold">5700+</div>
                <div class="text-sm text-slate-400 mt-1">Dohledaných pracovních commitů</div>
            </div>
            <div class="info-card">
                <div class="text-2xl font-semibold">TSM</div>
                <div class="text-sm text-slate-400 mt-1">2.2 / 2.4 produkce</div>
            </div>
            <div class="info-card">
                <div class="text-2xl font-semibold">Praha</div>
                <div class="text-sm text-slate-400 mt-1">Česká republika</div>
            </div>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Co přináším"
            body="Backendový profil doplněný o full-stack, data a produkční kontext tak, abych dokázal vlastnit reálné chování systému."
        />
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
            <InfoCard title="Produkční integrace">
                B2B API, procesní toky, zprávy, retry chování, logy a chybové stavy, které jsou důležité až po nasazení.
            </InfoCard>
            <InfoCard title="Release ownership">
                Nasazování nových verzí do reálných prostředí se zaměřením na kompatibilitu, data a provozní rizika.
            </InfoCard>
            <InfoCard title="Pragmatická architektura">
                Malé bezpečné změny, pojmenovaná business pravidla, jasné hranice služeb a kód připravený na další požadavky.
            </InfoCard>
            <InfoCard title="Full-stack kontext">
                Backendová práce s dostatečnou znalostí frontendu a databází pro pochopení celého produkčního flow.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Hlavní stack" />
        <div class="flex flex-wrap gap-2">
            <span class="pill">Kotlin</span>
            <span class="pill">Java</span>
            <span class="pill">Spring</span>
            <span class="pill">PostgreSQL</span>
            <span class="pill">Kafka</span>
            <span class="pill">Kubernetes</span>
            <span class="pill">Angular</span>
            <span class="pill">Oracle</span>
            <span class="pill">Astro</span>
            <span class="pill">TypeScript</span>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Zkušenosti v kostce"
            body="Většina mojí práce je interní nebo klientská, takže popisuji hlavně odpovědnost a produkční kontext místo ukazování kódu."
        />
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <InfoCard title="TSM / CETIN" meta="2020 - současnost" tag="hlavní fokus">
                Seniorní backend a integrační práce na Kotlin/Java/Spring službách, PostgreSQL systémech, B2B flow, PEW, NIP, change managementu a produkčních rolloutech nových verzí.
            </InfoCard>
            <InfoCard title="ZIS" meta="2017 - 2018" tag="základ">
                Enterprise Java a ZK/ZUL práce přes obrazovky, controllery, služby, DAO vrstvy, importy, Excel zpracování a produkční opravy.
            </InfoCard>
            <InfoCard title="MNCP" meta="2018 - 2021" tag="full-stack">
                Kotlin/Spring, Angular a databázová práce kolem autentizace, měřících dávek, archivů, exportů a provozních oprav.
            </InfoCard>
        </div>
    </section>

    <CtaBand
        title="Máš zájem o spolupráci?"
        body="Pokud hledáš seniorního vývojáře pro backend, integrace, produkční releasy nebo dlouhodobý vývoj produktu, nejrychlejší je e-mail."
        href="/cz/kontakt"
        label="Napiš mi"
    />

</Layout>
