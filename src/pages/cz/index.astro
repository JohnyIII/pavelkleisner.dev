---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import CtaBand from "@/components/CtaBand.astro";
import WarStory from "@/components/WarStory.astro";
---

<Layout title="Pavel Kleisner - Senior backend a integrační vývojář">

    <PageIntro
        eyebrow="Senior Backend & Integration Engineer"
        title="Pavel Kleisner"
        lead="Backend, integrace a releasy — ta nezáživná část, kde se systém potká s reálnými daty a má zůstat naživu."
        body="Dělám Kotlin/Java/Spring služby a PostgreSQL, hlavně kolem TSM/CETIN produkčního flow: B2B chování, datová kompatibilita, incidenty a rollout nových verzí. Radši opravím produkci, než abych měl pravdu."
        photo="/pavel.jpg"
        photoAlt="Pavel Kleisner"
    >
        <div slot="actions" class="flex flex-wrap gap-3 mt-8">
            <a href="/cz/projekty" class="btn-primary">Zkušenosti</a>
            <a href="/cz/kontakt" class="btn-secondary">Kontakt</a>
        </div>
    </PageIntro>

    <section class="mb-24">
        <div class="snapshot-list">
            <div>
                <div class="snapshot-key">Hlavní stack</div>
                <div class="snapshot-value">Kotlin · Java · Spring</div>
                <div class="snapshot-detail">PostgreSQL, Kafka-style messaging</div>
            </div>
            <div>
                <div class="snapshot-key">Produkční rollouty</div>
                <div class="snapshot-value">TSM <span class="accent-text">1.5 · 2.2 · 2.4</span></div>
                <div class="snapshot-detail">Hlavní vývojář u 2.2 / 2.4, podstatná součást u 1.5</div>
            </div>
            <div>
                <div class="snapshot-key">Zkušenost</div>
                <div class="snapshot-value">9+ let</div>
                <div class="snapshot-detail">Backend, integrace, full-stack epizody</div>
            </div>
            <div>
                <div class="snapshot-key">Působím v</div>
                <div class="snapshot-value">Praha · CET</div>
                <div class="snapshot-detail">Otevřený vzdálené spolupráci</div>
            </div>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Kde dávám největší smysl"
            body="Největší hodnota není v tom přidat další vrstvu abstrakce. Je v tom udělat změnu, která přežije data, integrace, support a další release."
        />
        <div class="fit-grid">
            <div class="fit-row">
                <div class="fit-cat">Integrace</div>
                <div class="fit-desc">B2B API, procesní toky, zprávy, retry chování, logy a chybové stavy, které začnou být důležité až po nasazení.</div>
            </div>
            <div class="fit-row">
                <div class="fit-cat">Releasy</div>
                <div class="fit-desc">Nasazování nových verzí do reálných prostředí se zaměřením na kompatibilitu, stará data a provozní rizika.</div>
            </div>
            <div class="fit-row">
                <div class="fit-cat">Architektura</div>
                <div class="fit-desc">Malé bezpečné změny, jasně pojmenovaná pravidla a hranice služeb. Bez divadla kolem patternů.</div>
            </div>
            <div class="fit-row">
                <div class="fit-cat">Debugging</div>
                <div class="fit-desc">Incidenty přes logy, metriky, databázi a doménový kontext. Ne přes náhodné patchování symptomů.</div>
            </div>
        </div>
    </section>

    <WarStory kicker="War story · anonymně" title="UUID, které nebylo UUID">
        <p class="mb-4">
            Při rolloutu první verze platformy slibovala kuchařka <code>messageId</code> jako
            UUID. Jednomu partnerovi to začalo hned padat. Jejich systém si potichu parsoval ID
            ticketu <em>ze</em> starého formátu <code>idTicketu_timestamp</code> — přestože ID
            ticketu měli rovnou v těle zprávy.
        </p>
        <p>
            Čistá oprava byla na jejich straně, jenže v korporátu by trvala měsíce. Tak jsem naši
            stranu přizpůsobil zpět původnímu tvaru a nechal produkci běžet. Někdy správné řešení
            není to čisté — je to to, které ve dvě ráno nerozbije někoho jiného.
        </p>
    </WarStory>

    <section class="mb-24">
        <SectionIntro title="Hlavní stack" />
        <div>
            <div class="stack-group">
                <div class="stack-label">Hlavní</div>
                <div class="stack-pills">
                    <span class="pill pill-strong">Kotlin</span>
                    <span class="pill pill-strong">Java</span>
                    <span class="pill pill-strong">Spring</span>
                    <span class="pill pill-strong">PostgreSQL</span>
                    <span class="pill pill-strong">Kafka</span>
                </div>
            </div>
            <div class="stack-group">
                <div class="stack-label">Také</div>
                <div class="stack-pills">
                    <span class="pill pill-muted">Kubernetes</span>
                    <span class="pill pill-muted">Oracle</span>
                    <span class="pill pill-muted">Angular</span>
                    <span class="pill pill-muted">Python / Django</span>
                    <span class="pill pill-muted">Astro</span>
                    <span class="pill pill-muted">TypeScript</span>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Zkušenosti v kostce"
            body="Většina mojí práce je interní nebo klientská, takže popisuji hlavně odpovědnost a produkční kontext místo ukazování kódu."
        />
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
            <InfoCard title="TSM / CETIN" meta="2020 - současnost" tag="hlavní fokus">
                Seniorní backend a integrační práce na Kotlin/Java/Spring službách, PostgreSQL systémech, B2B flow, PEW, NIP, change managementu a produkčních rolloutech nových verzí.
            </InfoCard>
            <InfoCard title="MNCP" meta="2018 - 2021" tag="full-stack">
                Kotlin/Spring, Angular a databázová práce kolem autentizace, měřících dávek, archivů, exportů a provozních oprav.
            </InfoCard>
            <InfoCard title="ZIS" meta="2017 - 2018" tag="základ">
                Enterprise Java a ZK/ZUL práce přes obrazovky, controllery, služby, DAO vrstvy, importy, Excel zpracování a produkční opravy.
            </InfoCard>
        </div>
    </section>

    <section class="offclock-line mb-24">
        <span class="offclock-kicker">Mimo klávesnici</span>
        <span>Hráč, čtenář a metalista z Podkrkonoší.</span>
        <a href="/cz/o-mne" class="offclock-link">Víc o mně →</a>
    </section>

    <CtaBand
        title="Máš zájem o spolupráci?"
        body="Pokud hledáš seniorního vývojáře pro backend, integrace, produkční releasy nebo dlouhodobý vývoj produktu, nejrychlejší je e-mail."
        href="/cz/kontakt"
        label="Napiš mi"
    />

</Layout>
