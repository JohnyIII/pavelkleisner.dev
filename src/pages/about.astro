---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import TimelineItem from "@/components/TimelineItem.astro";
import CtaBand from "@/components/CtaBand.astro";
import StatusReadout from "@/components/StatusReadout.astro";
---

<Layout title="About - Pavel Kleisner">

    <PageIntro
        title="Beyond"
        highlight="the code"
        lead="A calm, practical engineer who still genuinely enjoys making and fixing things."
        body="I've been at DataLite since 2017, growing from junior through senior engineer to team lead. I'm at my best where correctness, compatibility and release safety matter — where implementation meets domain behaviour, integration contracts and production. I like to help, keep learning, and never pretend to be more than I am."
        photo="/pavel.jpg"
        photoAlt="Pavel Kleisner"
        photoLabel="Human first · engineer second"
    />

    <section class="mb-24">
        <SectionIntro title="How I think about software" />
        <div class="cards-editorial">
            <InfoCard title="Small, explicit changes">
                In a live system a precisely named rule, an isolated mapping or one focused
                test usually beats a big rewrite. Less to go wrong at 2 a.m.
            </InfoCard>
            <InfoCard title="Modern when it pays off">
                I like new versions and tools — but only when they make the system more
                reliable, more observable or easier to change. Not for the CV.
            </InfoCard>
            <InfoCard title="It's not done at deploy">
                The real system starts after deployment: old data, retries, external
                contracts, logs, metrics and whoever has to support it.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Career path"
            body="A compressed timeline of how my responsibilities evolved across projects and stack changes."
        />
        <div class="timeline space-y-4">
            <TimelineItem title="2017-2018: ZIS">
                Enterprise Java, ZK/ZUL screens, controllers, services,
                DAO layers, imports and production fixes. This was the phase
                where I learned to deliver complete application features.
            </TimelineItem>
            <TimelineItem title="2018-2021: MNCP">
                Full-stack work across Kotlin/Spring, Angular and database scripts.
                I worked on security, exports, archives, measuring batches and operational
                fixes across the whole flow.
            </TimelineItem>
            <TimelineItem title="2020-present: TSM">
                Senior backend and integration work on Kotlin/Java/Spring services,
                PostgreSQL, Kafka-style integrations, B2B flows, incident analysis
                and production rollout of new platform versions.
            </TimelineItem>
            <TimelineItem title="2024-present: Nordic / Django (ad-hoc)">
                Ongoing on-demand collaboration in a Django stack, plus personal experiments.
                Low volume now, but the engagement stays open. A reminder that good engineering
                habits should transfer across stacks, not depend on one framework.
            </TimelineItem>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Working style" />
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <InfoCard title="Architecture and responsibility">
                Good architecture is not about complexity or diagrams. It is about
                responsibility, ownership and understanding where changes should
                and should not happen.
            </InfoCard>
            <InfoCard title="Collaboration">
                The best solutions usually come from collaboration between developers,
                analysts, product owners and operations. Technical decisions should
                serve the product and the people who keep it running.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="What I deliberately avoid" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <InfoCard title="Over-engineering">
                Architecture that doesn't remove real complexity, risk or maintenance
                cost. The "flexible" abstraction is usually the code everyone is
                afraid to touch two years later.
            </InfoCard>
            <InfoCard title="Big-bang releases">
                Shipping everything at once and hoping. A rollout needs an order,
                a fallback and a way to stop halfway — otherwise it's a bet.
            </InfoCard>
            <InfoCard title="One-person architecture">
                A system is not well designed if only one person can safely change it.
                I've been that person — it doesn't scale, and it ruins vacations.
            </InfoCard>
            <InfoCard title="Ego-driven choices">
                Technical decisions driven by taste instead of the product. I once
                adapted our side back to a partner's old format rather than defend
                a technically correct spec.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Off the clock"
            body="I build things end to end partly because I genuinely enjoy this stuff. Here's the human behind the commits."
        />

        <div class="personal-grid mb-6">
            <InfoCard title="Reading & audiobooks" variant="personal">
                Around 125 books and counting — LitRPG (Vasily Mahanenko), a lot of Czech
                sci-fi/fantasy (Kotleta, Sněgoňová, Starý, Kadlečková, Stehlíková), plus
                Andy Weir, Liu Cixin, Sapkowski and Pratchett. I do most of it as audiobooks.
            </InfoCard>
            <InfoCard title="Anime">
                Grew up on the shounen Big 3 (Naruto, One Piece, Bleach). One Piece is the
                one still running — and I'm still watching.
            </InfoCard>
            <InfoCard title="Gaming">
                My main way to switch off. PlayStation 5, currently playing 007 First Light.
            </InfoCard>
            <InfoCard title="Metal & coffee & bikes">
                Iron Maiden, Arch Enemy, Jinjer, HammerFall and friends in the headphones.
                Coffee ground fresh in a hand mill and brewed in a moka pot. A bike waiting
                for a rebuild. Cats and dogs both welcome.
            </InfoCard>
            <InfoCard title="Community" variant="personal">
                For two years I helped with a charity ball for Charita Červený Kostelec,
                mostly wherever another pair of hands was useful. I stopped after moving away,
                but it remains a good memory of practical local community work.
            </InfoCard>
        </div>

        <p class="card-body mb-4">Roots in Horní Radechová near Náchod; home today is just outside Prague.</p>
        <StatusReadout />
    </section>

    <CtaBand
        title="Let's work together"
        body="If this approach matches what you need, feel free to reach out."
        href="/contact"
        label="Contact me"
    />

</Layout>
