---
import Layout from "@/layouts/Layout.astro";
import PageIntro from "@/components/PageIntro.astro";
import SectionIntro from "@/components/SectionIntro.astro";
import InfoCard from "@/components/InfoCard.astro";
import TimelineItem from "@/components/TimelineItem.astro";
import CtaBand from "@/components/CtaBand.astro";
---

<Layout title="About - Pavel Kleisner">

    <PageIntro
        title="About"
        highlight="me"
        lead="I’m a senior backend and integration engineer focused on Kotlin, Java, Spring, PostgreSQL and production systems."
        body="I work best where correctness, compatibility, observability and release safety matter. My current profile is not only writing backend code. It is owning the part of the system where implementation, domain behavior, integration contracts and production releases overlap."
    />

    <section class="mb-24">
        <SectionIntro title="How I think about software" />
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <InfoCard title="Small explicit changes">
                In production systems, a precisely named business rule, isolated mapping,
                better fallback or focused test is often safer than a large rewrite.
            </InfoCard>
            <InfoCard title="Modern with a reason">
                New versions, frameworks and infrastructure matter when they make
                the system more reliable, observable or easier to change.
            </InfoCard>
            <InfoCard title="Runtime ownership">
                The real system starts after deployment: old data, retries,
                external contracts, logs, metrics and supportability.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro
            title="Career path"
            body="A compressed timeline of how my responsibilities evolved across projects and stack changes."
        />
        <div class="timeline space-y-4">
            <TimelineItem title="2017-2018: ZIS">
                Enterprise Java, ZK/ZUL screens, controllers, services,
                DAO layers, imports and production fixes. This was the phase
                where I learned to deliver complete application features.
            </TimelineItem>
            <TimelineItem title="2019-2020: MNCP">
                Full-stack work across Kotlin/Spring, Angular and database scripts.
                I worked on security, exports, archives, measuring batches and operational
                fixes across the whole flow.
            </TimelineItem>
            <TimelineItem title="2020-present: TSM">
                Senior backend and integration work on Kotlin/Java/Spring services,
                PostgreSQL, Kafka-style integrations, B2B flows, incident analysis
                and production rollout of new platform versions.
            </TimelineItem>
            <TimelineItem title="2024-present: wider stack">
                Smaller work in Nordic/Django and personal experiments.
                Useful mainly as a reminder that good engineering habits should
                transfer across stacks, not depend on one framework.
            </TimelineItem>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Working style" />
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <InfoCard title="Architecture and responsibility">
                Good architecture is not about complexity or diagrams. It is about
                responsibility, ownership and understanding where changes should
                and should not happen.
            </InfoCard>
            <InfoCard title="Collaboration">
                The best solutions usually come from collaboration between developers,
                analysts, product owners and operations. Technical decisions should
                serve the product and the people who keep it running.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="What I deliberately avoid" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <InfoCard title="Over-engineering">
                I avoid adding architecture that does not reduce real complexity,
                risk or maintenance cost.
            </InfoCard>
            <InfoCard title="Trend-driven decisions">
                I like modern tools, but only when they clearly improve delivery,
                reliability or developer understanding.
            </InfoCard>
            <InfoCard title="One-person architecture">
                A system is not well designed if only one person can safely change it.
            </InfoCard>
            <InfoCard title="Ego-driven choices">
                Technical decisions should serve the product and runtime behavior,
                not personal taste.
            </InfoCard>
        </div>
    </section>

    <section class="mb-24">
        <SectionIntro title="Beyond code" />
        <p class="max-w-4xl card-body leading-relaxed">
            Outside of work, I enjoy music, sci-fi, fantasy and anime.
            Side projects let me experiment, learn and explore ideas without the pressure
            of production deadlines. I like building things end to end because it keeps
            the whole product lifecycle visible: idea, implementation, deployment,
            maintenance and feedback.
        </p>
    </section>

    <CtaBand
        title="Let’s work together"
        body="If this approach matches what you need, feel free to reach out."
        href="/contact"
        label="Contact me"
    />

</Layout>
