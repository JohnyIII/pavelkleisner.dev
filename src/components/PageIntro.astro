---
const {
    eyebrow,
    title,
    highlight,
    lead,
    body,
} = Astro.props;
---

<section class="page-intro">
    {eyebrow && <div class="section-label mb-4">{eyebrow}</div>}
    <h1 class="page-title">
        {title}{highlight && <> <span class="accent-text">{highlight}</span></>}
    </h1>
    {lead && <p class="page-lead">{lead}</p>}
    {body && <p class="page-body">{body}</p>}
    <slot />
</section>
