---
import en from "@/i18n/en";
import cz from "@/i18n/cz";
import LanguageSwitch from "@/components/LanguageSwitch.astro";
import ThemeSwitch from "@/components/ThemeSwitch.astro";

const { lang = "en" } = Astro.props;
const t = lang === "cz" ? cz : en;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const enRoutes = [en.routes.home, en.routes.about, en.routes.projects, en.routes.contact];
const czRoutes = [cz.routes.home, cz.routes.about, cz.routes.projects, cz.routes.contact];

let altHref: string;
if (lang === "cz") {
    const idx = czRoutes.indexOf(pathname);
    altHref = idx >= 0 ? enRoutes[idx] : "/";
} else {
    const idx = enRoutes.indexOf(pathname);
    altHref = idx >= 0 ? czRoutes[idx] : "/cz";
}
---

<div class="site-nav-wrap">
    <nav class="site-nav" aria-label="Primary">
        <a href={t.routes.home} class:list={["nav-link", { active: pathname === t.routes.home }]} aria-current={pathname === t.routes.home ? "page" : undefined}>{t.nav.home}</a>
        <a href={t.routes.about} class:list={["nav-link", { active: pathname === t.routes.about }]} aria-current={pathname === t.routes.about ? "page" : undefined}>{t.nav.about}</a>
        <a href={t.routes.projects} class:list={["nav-link", { active: pathname === t.routes.projects }]} aria-current={pathname === t.routes.projects ? "page" : undefined}>{t.nav.projects}</a>
        <a href={t.routes.contact} class:list={["nav-link", { active: pathname === t.routes.contact }]} aria-current={pathname === t.routes.contact ? "page" : undefined}>{t.nav.contact}</a>
    </nav>

    <div class="header-tools">
        <LanguageSwitch lang={lang} altHref={altHref} />
        <ThemeSwitch lang={lang} />
    </div>
</div>
