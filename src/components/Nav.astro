---
import en from "@/i18n/en";
import cz from "@/i18n/cz";
import LanguageSwitch from "@/components/LanguageSwitch.astro";
import ThemeSwitch from "@/components/ThemeSwitch.astro";

const { lang = "en" } = Astro.props;
const t = lang === "cz" ? cz : en;
---



<div class="site-nav-wrap">
    <nav class="site-nav">
        <a
                href={t.routes.home}
                class="nav-link">            {t.nav.home}
        </a>
        <a href={t.routes.about} class="nav-link">
            {t.nav.about}
        </a>
        <a href={t.routes.projects} class="nav-link">
            {t.nav.projects}
        </a>
        <a href={t.routes.contact} class="nav-link">
            {t.nav.contact}
        </a>
    </nav>

    <ThemeSwitch />
    <LanguageSwitch lang={lang} />
</div>
