---
const {
    title,
    body,
    href,
    label,
} = Astro.props;
---

<section class="cta-band">
    <div class="cta-copy">
        <span class="cta-mark" aria-hidden="true">↗</span>
        <h2>{title}</h2>
        {body && <p>{body}</p>}
    </div>
    {href && label && <a href={href} class="btn-primary">{label}</a>}
</section>
