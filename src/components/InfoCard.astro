---
const {
    title,
    tag,
    meta,
} = Astro.props;
---

<article class="info-card">
    <div class="flex flex-wrap items-start justify-between gap-3 mb-3">
        <div>
            <h3 class="text-xl font-semibold">{title}</h3>
            {meta && <p class="card-meta mt-1">{meta}</p>}
        </div>
        {tag && <span class="tag">{tag}</span>}
    </div>
    <div class="card-body">
        <slot />
    </div>
</article>
