---
const {
    title,
    period,
} = Astro.props;
---

<article class="timeline-item">
    <span class="timeline-dot" aria-hidden="true"></span>
    <div class="flex flex-wrap items-center gap-3 mb-3">
        <h3 class="text-2xl font-semibold">{title}</h3>
        {period && <span class="card-meta">{period}</span>}
    </div>
    <div class="card-body">
        <slot />
    </div>
</article>
