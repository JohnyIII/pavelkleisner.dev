---
import "../styles/global.css";
import Nav from "@/components/Nav.astro";

const { title = "Pavel Kleisner" } = Astro.props;

const pathname = Astro.url.pathname;
const lang = pathname.startsWith("/cz") ? "cz" : "en";
---

<!doctype html>
<html lang={lang} data-theme="void">
<head>
	<meta charset="utf-8" />
	<script is:inline>
		try {
			document.documentElement.dataset.theme = localStorage.getItem("pavelkleisner-theme") || "void";
		} catch {
			document.documentElement.dataset.theme = "void";
		}
	</script>
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Rajdhani:wght@500;600;700&family=Source+Serif+4:opsz,wght@8..60,600;8..60,700&display=swap" rel="stylesheet" />
	<title>{title}</title>
	<meta
		name="description"
		content="Senior backend and integration engineer focused on Kotlin, Java, Spring, PostgreSQL, production releases, and telecom-grade systems."
	/>

	<!-- Open Graph / LinkedIn -->
	<meta property="og:type" content="website" />
	<meta property="og:title" content={title} />
	<meta
		property="og:description"
		content="Senior backend and integration engineer focused on Kotlin, Java, Spring, PostgreSQL, production releases, and telecom-grade systems."
	/>
	<meta property="og:url" content={Astro.url.href} />
	<meta property="og:image" content="/og-image.png" />

	<!-- Twitter -->
	<meta name="twitter:card" content="summary_large_image" />
	<meta name="twitter:title" content={title} />
	<meta
		name="twitter:description"
		content="Senior backend and integration engineer focused on Kotlin, Java, Spring, PostgreSQL, production releases, and telecom-grade systems."
	/>
	<meta name="twitter:image" content="/og-image.png" />
</head>
<body class="min-h-screen antialiased">
<div class="bg-ambient" aria-hidden="true"></div>
<header class="site-header">
	<div class="max-w-6xl mx-auto px-5 sm:px-6 py-5 flex flex-wrap justify-between items-center gap-4">
        <span class="site-mark">
          Pavel Kleisner <span class="accent-text">/ backend</span>
        </span>

		<Nav lang={lang} />
	</div>
</header>

<main class="max-w-6xl mx-auto px-5 sm:px-6 py-14 sm:py-20">
	<slot />
</main>

<footer class="site-footer mt-20">
	<div class="max-w-6xl mx-auto px-5 sm:px-6 py-8 text-sm">
		© {new Date().getFullYear()} Pavel Kleisner
	</div>
</footer>
</body>
</html>
